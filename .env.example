# ============================================================================
# mcp-media-toolkit - Environment Variables
# ============================================================================

# ----------------------------------------------------------------------------
# Image Generation (Gemini) - REQUIRED
# ----------------------------------------------------------------------------
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ----------------------------------------------------------------------------
# Image Storage (S3-compatible) - OPTIONAL (only needed for upload)
# ----------------------------------------------------------------------------
# All S3_* variables must be set together for upload to work.
# Works with Cloudflare R2, AWS S3, MinIO, DigitalOcean Spaces, etc.

# Endpoint URL of your S3-compatible storage
#   Cloudflare R2:     https://<account-id>.r2.cloudflarestorage.com
#   AWS S3:            https://s3.<region>.amazonaws.com
#   MinIO:             https://minio.example.com
#   DO Spaces:         https://<region>.digitaloceanspaces.com
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Credentials
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Bucket name
S3_BUCKET=media

# Public base URL where uploaded files are accessible.
# Must NOT have a trailing slash.
#   Cloudflare R2:     https://pub-<hash>.r2.dev  or  https://media.example.com
#   AWS S3:            https://<bucket>.s3.<region>.amazonaws.com
#   MinIO:             https://minio.example.com/<bucket>
S3_PUBLIC_URL=https://media.example.com

# Region ("auto" for R2, "us-east-1" for S3/MinIO, etc.)
S3_REGION=auto

# ----------------------------------------------------------------------------
# Optional
# ----------------------------------------------------------------------------
# Default directory for generated images (absolute path).
# Defaults to ~/Pictures/mcp-media/ if not set.
# IMAGE_OUTPUT_DIR=/absolute/path/to/output
